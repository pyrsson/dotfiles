layer-rule {
    match namespace="^hyprpaper$"
    match namespace="^wallpaper$"
    place-within-backdrop true
}
layer-rule {
    match namespace="^vibepanel.*$"
    exclude namespace="^vibepanel-click-catcher$"
    background-effect {
        blur true
        xray false
    }
    popups {
        background-effect {
            blur true
            xray false
        }
    }
}
layer-rule {
    match namespace="walker"
    background-effect {
        xray false
    }
}
