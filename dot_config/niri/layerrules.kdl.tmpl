layer-rule {
    match namespace="^hyprpaper$"
    match namespace="^wallpaper$"
    match namespace="^awww-daemonbg$"
    place-within-backdrop true
    background-effect {
        xray false
        blur true
    }
}

layer-rule {
    match namespace="^vibepanel.*$"
    exclude namespace="^vibepanel$"
    background-effect {
        xray false
    }
    popups {
        background-effect {
            xray false
        }
    }
}

layer-rule {
    match namespace="walker"
    background-effect {
        xray false
    }
}
