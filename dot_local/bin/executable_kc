#!/bin/bash

# Switch between kubeconfig files
# Usage: kc <kubeconfig>

FZF_DEFAULT_OPTS+=" --reverse --no-separator --info hidden --border rounded --ansi"

current="$(readlink ~/.kube/config | cut -d/ -f2)"
desired_kubeconfig="$1"
green=$(printf '\033[32;1m')
reset=$(printf '\033[0m')

if [[ "$desired_kubeconfig" == "-" ]]; then
  if [[ ! -f ~/.kube/kc ]]; then
    echo "No previous kubeconfig recorded" >&2
    exit 1
  fi
  desired_kubeconfig="$(cat ~/.kube/kc)"
fi

if [[ -z "$desired_kubeconfig" ]]; then
  desired_kubeconfig="$(fd --base-directory ~/.kube/config.d/ | sed "s/^${current}$/${green}${current}${reset}/" | fzf --prompt "Select kubeconfig > ")"
  if [[ -z "$desired_kubeconfig" ]]; then
    exit 1
  fi
fi

if [[ "$desired_kubeconfig" != "$current" ]]; then
  echo "$current" >~/.kube/kc
  rm -f ~/.kube/config
  ln -rs ~/.kube/config.d/"$desired_kubeconfig" ~/.kube/config || exit 1
  echo "Switched to $desired_kubeconfig"
fi
