#!/usr/bin/env bash

current=$(yq '.data.theme' ~/.config/chezmoi/chezmoi.yaml)

if [[ "$1" == "check" ]]; then
  jq -ncj --arg theme "$current" '{"tooltip": "Current mode: "+$theme, "alt": $theme}'
  exit 0
fi

if [[ "$current" == "dark" ]]; then
  yq -i '.data.theme = "light"' ~/.config/chezmoi/chezmoi.yaml
else
  yq -i '.data.theme = "dark"' ~/.config/chezmoi/chezmoi.yaml
fi

chezmoi apply
